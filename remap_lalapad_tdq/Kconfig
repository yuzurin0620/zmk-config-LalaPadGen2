menuconfig ZMK_BEHAVIOR_TAP_DANCE_TRIPLE
    bool "Triple tap-dance behavior"
    default y
    help
      Enable a three-state tap-dance behavior with single tap, single hold,
      and double tap outputs.

if ZMK_BEHAVIOR_TAP_DANCE_TRIPLE

config ZMK_BEHAVIOR_TAP_DANCE_TRIPLE_MAX_HELD
    int "Maximum simultaneous triple tap dances"
    default 10
    help
      Maximum number of active triple tap-dance keys that may be tracked at once.

endif
